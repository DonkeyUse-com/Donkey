DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-web-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-web-client-secret"
DONKEY_MAC_AUTH_REDIRECT_ORIGINS="donkey://"
DONKEY_MAC_AUTH_CALLBACK_SCHEME="donkey"

# The following are used for server-side inference calls.
OPENROUTER_API_KEY="replace-with-openrouter-api-key"
ELEVENLABS_API_KEY="replace-with-elevenlabs-api-key"
DONKEY_INFERENCE_HTTP_REFERER="http://localhost:3000"
DONKEY_INFERENCE_TITLE="Donkey"

# Gemini / Google Cloud inference uses Vertex AI by default so Google Cloud
# credits apply. Authenticate the backend with Application Default Credentials
# or GOOGLE_APPLICATION_CREDENTIALS outside this committed file.
GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT="replace-with-google-cloud-project-id"
GOOGLE_CLOUD_LOCATION="global"
# Optional backend-only Gemini model overrides.
# GEMINI_RESPONSES_MODEL="gemini-2.5-flash"
# GEMINI_COMPUTER_MODEL="gemini-2.5-computer-use-preview-10-2025"

# Optional development fallback for Google AI Studio / Gemini API keys.
# GEMINI_PROVIDER_MODE="api-key"
# GEMINI_API_KEY="replace-with-gemini-api-key"
