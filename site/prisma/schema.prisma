// Migrations are manual-only in this repo. Do not run Prisma migrate/db push
// or commit generated migration files unless explicitly asked to create the
// handwritten migration artifact.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InferenceGeneration {
  id                   String    @id @default(cuid())
  clientId             String
  kind                 String
  status               String    @default("pending")
  provider             String
  model                String
  providerJobId        String?
  providerGenerationId String?
  providerPollingUrl   String?
  promptPreview        String
  requestHash          String
  request              Json
  outputs              Json?
  usage                Json?
  error                Json?
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  @@index([clientId, createdAt])
  @@index([provider, providerJobId])
  @@index([status, updatedAt])
}
